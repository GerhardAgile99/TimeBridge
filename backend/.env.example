# Server
PORT=4000
NODE_ENV=development

# Database (Docker defaults)
DATABASE_URL=postgresql://flowtrack:flowtrack_dev@localhost:5432/flowtrack

# Redis (Docker default)
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Auth (generate a random 32+ char string)
JWT_SECRET=change_me_in_production_use_random_string_here

# Optional: Supabase (leave blank if using Docker Postgres)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Webhook secrets (add when configuring integrations)
SLACK_SIGNING_SECRET=
GITHUB_WEBHOOK_SECRET=
